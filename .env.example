# ============================================================================
# Configuração da Aplicação — URL Shortener System
# ============================================================================
# Copie este arquivo para .env e ajuste os valores conforme necessário.

# API
APP_HOST=0.0.0.0
APP_PORT=8000
BASE_URL=http://localhost

# Cassandra
CASSANDRA_HOST=cassandra
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=url_shortener
CASSANDRA_DC=datacenter1
CASSANDRA_USER=
CASSANDRA_PASSWORD=

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Segurança — HashIds
# IMPORTANTE: Altere este valor para uma string única e segura em produção.
# Isso garante a ofuscação dos shortcodes e previne enumeração sequencial.
HASHIDS_SALT=chave-secreta-altere-isso-em-producao

# Cache
# TTL em segundos. Padrão: 86400 (24 horas)
CACHE_TTL=86400
